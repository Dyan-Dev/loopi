{
  "id": "game-cookie-clicker",
  "name": "Cookie Clicker Auto-Player",
  "description": "Plays Cookie Clicker — auto-clicks the big cookie, tracks score, and buys the cheapest upgrade in a loop. Great for demoing real browser automation on an interactive page.",
  "nodes": [
    {
      "id": "1",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "1",
          "type": "navigate",
          "description": "Open Cookie Clicker",
          "value": "https://orteil.dashnet.org/cookieclicker/"
        }
      },
      "position": { "x": 400, "y": 50 }
    },
    {
      "id": "2",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "2",
          "type": "wait",
          "description": "Wait for game to load",
          "value": "5"
        }
      },
      "position": { "x": 400, "y": 150 }
    },
    {
      "id": "3",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "3",
          "type": "codeExecute",
          "description": "Accept cookie consent if present",
          "code": "try { const btn = document.querySelector('.cc_btn_accept_all, .fc-cta-consent, a.cc_btn'); if (btn) btn.click(); } catch(e) {} return 'done';"
        }
      },
      "position": { "x": 400, "y": 250 }
    },
    {
      "id": "4",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "4",
          "type": "wait",
          "description": "Let game finish loading assets",
          "value": "3"
        }
      },
      "position": { "x": 400, "y": 350 }
    },
    {
      "id": "5",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "5",
          "type": "codeExecute",
          "description": "Select English language if prompted",
          "code": "try { const langBtn = document.getElementById('langSelect-EN'); if (langBtn) langBtn.click(); } catch(e) {} return 'done';"
        }
      },
      "position": { "x": 400, "y": 450 }
    },
    {
      "id": "6",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "6",
          "type": "wait",
          "description": "Wait for language selection",
          "value": "3"
        }
      },
      "position": { "x": 400, "y": 550 }
    },
    {
      "id": "7",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "7",
          "type": "setVariable",
          "description": "Set click round counter",
          "variableName": "round",
          "value": "0"
        }
      },
      "position": { "x": 400, "y": 650 }
    },
    {
      "id": "8",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "8",
          "type": "setVariable",
          "description": "Set total rounds to play",
          "variableName": "maxRounds",
          "value": "15"
        }
      },
      "position": { "x": 400, "y": 750 }
    },
    {
      "id": "9",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "9",
          "type": "codeExecute",
          "description": "Rapid-click the big cookie 30 times",
          "code": "const cookie = document.getElementById('bigCookie'); for (let i = 0; i < 30; i++) { cookie.click(); } return 'Clicked 30 times';"
        }
      },
      "position": { "x": 400, "y": 870 }
    },
    {
      "id": "10",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "10",
          "type": "wait",
          "description": "Brief pause between rounds",
          "value": "1"
        }
      },
      "position": { "x": 400, "y": 970 }
    },
    {
      "id": "11",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "11",
          "type": "codeExecute",
          "description": "Extract current cookie count",
          "code": "const el = document.getElementById('cookies'); return el ? el.textContent.split(' ')[0] : '0';",
          "storeKey": "cookieCount"
        }
      },
      "position": { "x": 400, "y": 1070 }
    },
    {
      "id": "12",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "12",
          "type": "codeExecute",
          "description": "Try to buy the cheapest available upgrade",
          "code": "const products = document.querySelectorAll('.product.unlocked.enabled'); if (products.length > 0) { products[0].click(); return 'Bought: ' + products[0].querySelector('.title')?.textContent; } return 'Nothing affordable yet';",
          "storeKey": "purchaseResult"
        }
      },
      "position": { "x": 400, "y": 1170 }
    },
    {
      "id": "13",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "13",
          "type": "modifyVariable",
          "description": "Increment round counter",
          "variableName": "round",
          "operation": "increment",
          "value": "1"
        }
      },
      "position": { "x": 400, "y": 1270 }
    },
    {
      "id": "14",
      "type": "variableConditional",
      "data": {
        "step": {
          "id": "14",
          "type": "variableConditional",
          "description": "Check if we have more rounds to play",
          "variableConditionType": "variableLessThan",
          "variableName": "round",
          "comparisonValue": "{{maxRounds}}",
          "parseAsNumber": true
        }
      },
      "position": { "x": 400, "y": 1370 }
    },
    {
      "id": "15",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "15",
          "type": "screenshot",
          "description": "Take final screenshot of cookie empire",
          "savePath": "cookie_clicker_result.png"
        }
      },
      "position": { "x": 700, "y": 1370 }
    },
    {
      "id": "16",
      "type": "automationStep",
      "data": {
        "step": {
          "id": "16",
          "type": "codeExecute",
          "description": "Get final game stats",
          "code": "const cookies = document.getElementById('cookies')?.textContent || '0'; const cps = document.getElementById('cookiesPerSecond')?.textContent || '0'; return JSON.stringify({ cookies, cps });",
          "storeKey": "finalStats"
        }
      },
      "position": { "x": 700, "y": 1470 }
    }
  ],
