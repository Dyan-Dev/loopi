{
  "compilerOptions": {
    "target": "ES2024",
    "allowJs": true,
    "module": "preserve",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "paths": {
      "@src/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@main/*": ["./src/main/*"],
      "@app-types/*": ["./src/types/*"],
      "@app-types": ["./src/types/index.ts"],
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src/**/*"]
}
